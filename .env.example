# Copy this file to .env and fill in real values for local development.
# app.py loads .env automatically via python-dotenv.

# Required outside of local development (FLASK_DEBUG=1). Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Set to 1 for local development. Enables Flask's debug/auto-reload AND
# allows the app to fall back to an insecure development SECRET_KEY.
FLASK_DEBUG=1

# Optional: path to the SQLite database file. Defaults to users.db.
# DATABASE_PATH=users.db
